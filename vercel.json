{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "slturismo.com" }],
      "destination": "https://www.slturismo.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate, s-maxage=0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/og-image.jpg" },
    { "source": "/", "destination": "/index.html" },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
