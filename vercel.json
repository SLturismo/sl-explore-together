{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "slturismo.com" }],
      "destination": "https://www.slturismo.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/og-image.jpg" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
